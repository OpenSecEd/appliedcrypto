@Article{pQBL,
AUTHOR = {Bälter, Olle and Glassey, Richard and Jemstedt, Andreas and Bosk, Daniel},
TITLE = {Pure Question-Based Learning},
JOURNAL = {Education Sciences},
VOLUME = {14},
YEAR = {2024},
NUMBER = {8},
ARTICLE-NUMBER = {882},
ISSN = {2227-7102},
ABSTRACT = {We have evaluated a new pedagogical approach, pure question-based learning, or rather, a modern, digitized version of a really old approach: the Socratic method of learning. The pedagogical approach was evaluated and improved using a design-based research methodology. An online course was developed with pure question-based learning to explain its predecessor: question-based learning. The course was successively taken by students, researchers, and practitioners, and discussed in four group seminars. Feedback from each iteration was integrated into the next version and the course is still in use, see link below. Results from the design-based research process were positive (n≈78 participants, over four iterations) with the main negative results coming from the unfamiliarity of the format and feelings of exam-like stress during the first encounter. While pure question-based learning is new, it builds upon well-tested pedagogical methods. The method has several potential advantages: learning can be broken down into smaller modules, there is less passive learning for the students, less learning material needs to be created and AI could be used for this creation.},
DOI = {10.3390/educsci14080882}
}




